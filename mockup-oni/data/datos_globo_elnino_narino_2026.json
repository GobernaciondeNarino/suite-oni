  "mecanismo": {
    "que_lo_produce": "El Niño es la fase cálida del ciclo ENSO: un calentamiento anómalo y sostenido de las aguas superficiales del océano Pacífico ecuatorial centro-oriental, acompañado del debilitamiento de los vientos alisios que normalmente empujan el agua cálida hacia el oeste.",
    "como_se_genera": [
      {
        "paso": 1,
        "titulo": "Estado normal",
        "texto": "Los vientos alisios soplan de este a oeste y acumulan agua cálida en el Pacífico occidental; en el oriente aflora agua fría (surgencia)."
      },
      {
        "paso": 2,
        "titulo": "Debilitamiento de alisios",
        "texto": "Los vientos alisios se debilitan o invierten, reduciendo la surgencia de agua fría en el Pacífico oriental."
      },
      {
        "paso": 3,
        "titulo": "Calentamiento del Pacífico",
        "texto": "El agua cálida se desplaza hacia el este; la temperatura superficial del mar sube por encima del promedio (anomalía positiva en la región Niño-3.4)."
      },
      {
        "paso": 4,
        "titulo": "Cambio atmosférico",
        "texto": "Se altera la circulación atmosférica (celda de Walker), desplazando las zonas de lluvia."
      },
      {
        "paso": 5,
        "titulo": "Efecto en Colombia/Nariño",
        "texto": "Disminuyen las lluvias y suben las temperaturas, generando déficit hídrico, mayor riesgo de incendios y presión sobre agricultura y salud."
      }
    ],
    "indicadores": [
      "Índice Niño-3.4",
      "Índice Oceánico de El Niño (ONI)"
    ]
  },
